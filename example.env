# Required (default configured for Gemini)
GOOGLE_API_KEY=your-gemini-api-key

# Optional: Override the default Gemini model
# AGNO_MODEL_ID=gemini-2.0-flash

# Optional: Use a different model provider
# OPENAI_API_KEY=sk-***
# ANTHROPIC_API_KEY=sk-ant-***

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# Scheduler (set in production to point to your AgentOS URL)
# AGENTOS_URL=https://your-agentos-url.com
